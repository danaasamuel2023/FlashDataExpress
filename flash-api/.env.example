# Required
MONGODB_URI=mongodb://localhost:27017/flashdata
JWT_SECRET=replace-me

# Strongly recommended — used to encrypt Paystack transfer key (and any
# future DB-stored secrets). MUST be stable across deploys; rotating it
# invalidates all existing ciphertexts. Falls back to JWT_SECRET if unset.
ENCRYPTION_KEY=replace-with-a-long-random-string

FRONTEND_URL=http://localhost:3000
PORT=4000
